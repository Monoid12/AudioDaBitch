#!/bin/bash
set +e
APP="/Applications/AudioDaBitch.app"
if [ ! -d "$APP" ]; then
  echo "FEHLER: $APP wurde nicht installiert." >&2
  exit 1
fi
if [ ! -x "$APP/Contents/MacOS/AudioDaBitch" ]; then
  echo "FEHLER: App-Binary fehlt oder ist nicht ausführbar." >&2
  exit 1
fi
if [ ! -f "$APP/Contents/Resources/engine.py" ]; then
  echo "FEHLER: engine.py fehlt im App-Bundle." >&2
  exit 1
fi
/usr/bin/xattr -dr com.apple.quarantine "$APP" 2>/dev/null
# Do not auto-start during normal pkg install. In-app updater may restart separately.
exit 0
