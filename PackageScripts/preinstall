#!/bin/bash
set +e
/usr/bin/pkill -f '/AudioDaBitch.app/.*/engine.py' 2>/dev/null || true
/usr/bin/pkill -f 'Resources/engine.py' 2>/dev/null || true
/usr/bin/pkill -f 'audiodabitch_engine.py' 2>/dev/null || true
/bin/sleep 0.3
/usr/sbin/lsof -tiTCP:49372 -sTCP:LISTEN | /usr/bin/xargs -r /bin/kill -TERM 2>/dev/null || true
/bin/sleep 0.2
/usr/sbin/lsof -tiTCP:49372 -sTCP:LISTEN | /usr/bin/xargs -r /bin/kill -KILL 2>/dev/null || true
/bin/rm -rf /Applications/AudioDaBitch.app
/bin/rm -f "$HOME/Library/Application Support/AudioDaBitch/engine.pid" 2>/dev/null || true
exit 0
